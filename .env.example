APP_VERSION="1.0.0"
APP_TITLE="black-diamond-hubspot-service"
FLASK_ENV="development"
FLASK_DEBUG=true
SECRET_KEY="REPLACE_WITH_SECRET_KEY"
PORT=5720
HOST="0.0.0.0"
ENVIRONMENT="dev"

LOG_LEVEL="DEBUG"
LOG_FORMAT="text"
LOKI_ENABLED=false

DB_HOST=""
DB_PORT=5432
DB_NAME="hubspot_dev"
DB_USER="dev_user"
DB_PASSWORD="REPLACE_WITH_DB_PASSWORD"
DB_SCHEMA="public"

HUBSPOT_ACCESS_TOKEN="REPLACE_WITH_HUBSPOT_ACCESS_TOKEN"
HUBSPOT_PORTAL_ID="REPLACE_WITH_HUBSPOT_PORTAL_ID"
HUBSPOT_BASE_URL="https://api.hubapi.com"
HUBSPOT_API_VERSION="v3"
HUBSPOT_PAGE_SIZE=100
HUBSPOT_RATE_LIMIT_RPS=10
HUBSPOT_INCLUDE_ASSOCIATIONS=true

MAX_CONCURRENT_SCANS=2
SCAN_TIMEOUT_HOURS=2
CLEANUP_DAYS=7

HMAC_ENABLED=false
HMAC_SECRET_KEY_CORE="REPLACE_WITH_HMAC_SECRET_KEY_CORE"
HMAC_SECRET_KEY_ENGINEER="REPLACE_WITH_HMAC_SECRET_KEY_ENGINEER"
HMAC_SIGNATURE_MAX_AGE=300

MINIO_ENABLED=false
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="REPLACE_WITH_MINIO_ACCESS_KEY"
MINIO_SECRET_KEY="REPLACE_WITH_MINIO_SECRET_KEY"
MINIO_SECURE=false
MINIO_BUCKET="hubspot-dev"

KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
KAFKA_CONSUMER_GROUP_ID="hs-service-dev"
KAFKA_AUTO_OFFSET_RESET="earliest"
KAFKA_ENABLE_AUTO_COMMIT=true

CLICKHOUSE_ENABLED=false
CLICKHOUSE_HOST="localhost"
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER="default"
CLICKHOUSE_PASSWORD="REPLACE_WITH_CLICKHOUSE_PASSWORD"
CLICKHOUSE_DATABASE="hubspot"

PII_MASKING_ENABLED=false
PII_SERVICE_URL="http://localhost:8100"
PII_HMAC_KEY="REPLACE_WITH_PII_HMAC_KEY"
PII_SERVICE_ID="hs-service-dev"

ALLOWED_ORIGINS="*"
BD_CORE_URL="http://localhost:5700"
